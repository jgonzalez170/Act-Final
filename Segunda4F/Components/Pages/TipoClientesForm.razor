@page "/tipoclientes/nueva"
@page "/tipoclientes/editar/{Id:int}"

@rendermode InteractiveServer

@using Segunda4F.Data
@using Segunda4F.Repositorios

@inject IRepositorioTipoClientes _repositorioTipoClientes
@inject NavigationManager _navigationManager

<PageTitle>@(Id.HasValue && Id.Value > 0 ? "Editar Tipo de Cliente" : "Nuevo Tipo de Cliente")</PageTitle>

@if (_error)
{
    <div class="form-alert form-alert-danger">
        <span class="alert-icon">⚠</span>
        No se encontró el tipo de cliente.
    </div>
}
else
{
    <div class="form-card">

        <div class="form-card-header">
            <h3 class="form-card-title">
                @(Id.HasValue && Id.Value > 0 ? "Editar Tipo de Cliente" : "Nuevo Tipo de Cliente")
            </h3>
            <p class="form-card-subtitle">
                @(Id.HasValue && Id.Value > 0
                    ? "Modifica el nombre del tipo de cliente"
                    : "Ingresa el nombre del nuevo tipo de cliente")
            </p>
        </div>

        <EditForm Model="_tipoCliente"
                  FormName="frmTipoCliente"
                  OnValidSubmit="Guardar">

            <DataAnnotationsValidator />
            <ValidationSummary class="form-validation-summary" />

            <div class="form-section">
                <h4 class="form-section-title">Información</h4>

                <div class="form-field">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-input"
                               placeholder="Ej. Premium, Frecuente, VIP…"
                               @bind-Value="_tipoCliente.Nombre" />
                    <ValidationMessage For="@(() => _tipoCliente.Nombre)" />
                </div>
            </div>

            <div class="form-actions">
                <button type="button"
                        class="btn-form-cancel"
                        @onclick="Cancelar">
                    Cancelar
                </button>
                <button type="submit"
                        class="btn-form-save">
                    @(Id.HasValue && Id.Value > 0 ? "Guardar cambios" : "Crear tipo")
                </button>
            </div>

        </EditForm>

    </div>
}

@code {

    [Parameter]
    public int? Id { get; set; }

    private TipoCliente _tipoCliente = new();

    private bool _error = false;

    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue && Id.Value > 0)
        {
            var tipo = await _repositorioTipoClientes
                .ObtenerTipoClientePorId(Id.Value);

            if (tipo == null)
                _error = true;
            else
                _tipoCliente = tipo;
        }
    }

    private async Task Guardar()
    {
        if (Id.HasValue && Id.Value > 0)
            await _repositorioTipoClientes.ActualizarTipoCliente(_tipoCliente);
        else
            await _repositorioTipoClientes.AgregarTipoCliente(_tipoCliente);

        _navigationManager.NavigateTo("/tipoclientes");
    }

    private void Cancelar()
    {
        _navigationManager.NavigateTo("/tipoclientes");
    }
}
