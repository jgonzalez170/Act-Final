@page "/clientes/nueva"
@page "/clientes/editar/{Id:int}"

@rendermode InteractiveServer

@using Segunda4F.Data
@using Segunda4F.Repositorios

@inject IRepositorioClientes _repositorioClientes
@inject IRepositorioTipoClientes _repositorioTipoClientes
@inject IRepositorioIntereses _repositorioIntereses
@inject NavigationManager _navigationManager

<PageTitle>@(Id.HasValue && Id.Value > 0 ? "Editar Cliente" : "Nuevo Cliente")</PageTitle>

@if (_error)
{
    <div class="form-alert form-alert-danger">
        <span class="alert-icon">⚠</span>
        No se encontró el cliente.
    </div>
}
else
{
    <div class="form-card">

        <div class="form-card-header">
            <h3 class="form-card-title">
                @(Id.HasValue && Id.Value > 0 ? "Editar Cliente" : "Nuevo Cliente")
            </h3>
            <p class="form-card-subtitle">
                @(Id.HasValue && Id.Value > 0
                    ? "Modifica los datos del cliente"
                    : "Completa los datos para registrar un nuevo cliente")
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_mensajeError))
        {
            <div class="form-alert form-alert-danger">
                <span class="alert-icon">⚠</span>
                @_mensajeError
            </div>
        }

        <EditForm Model="_cliente"
                  FormName="frmCliente"
                  OnValidSubmit="Guardar">

            <DataAnnotationsValidator />
            <ValidationSummary class="form-validation-summary" />

            <div class="form-section">
                <h4 class="form-section-title">Información general</h4>

                <div class="form-field">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-input"
                               placeholder="Nombre completo"
                               @bind-Value="_cliente.Nombre" />
                </div>

                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label">Teléfono</label>
                        <InputText class="form-input"
                                   maxlength="10"
                                   placeholder="10 dígitos"
                                   @bind-Value="_cliente.Telefono" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">Correo electrónico</label>
                        <InputText class="form-input"
                                   placeholder="correo@ejemplo.com"
                                   @bind-Value="_cliente.Correo" />
                    </div>
                </div>

                <div class="form-field">
                    <label class="form-label">Tipo de cliente</label>
                    <InputSelect class="form-input form-select-input"
                                 @bind-Value="_cliente.TipoClienteId">
                        <option value="">— Seleccione un tipo —</option>
                        @foreach (var tipo in _tiposCliente)
                        {
                            <option value="@tipo.Id">@tipo.Nombre</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="form-section">
                <h4 class="form-section-title">Intereses</h4>
                <p class="form-section-hint">Selecciona todos los que apliquen</p>

                <div class="intereses-grid">
                    @foreach (var interes in _intereses)
                    {
                        var seleccionado = IsInteresSeleccionado(interes.Id);
                        <label class="interes-chip @(seleccionado ? "interes-chip-active" : "")">
                            <input type="checkbox"
                                   checked="@seleccionado"
                                   @onchange="(e) => OnInteresChanged(interes.Id, Convert.ToBoolean(e.Value))" />
                            @interes.Nombre
                        </label>
                    }
                </div>
            </div>

            <div class="form-actions">
                <button type="button"
                        class="btn-form-cancel"
                        @onclick="Cancelar">
                    Cancelar
                </button>
                <button type="submit"
                        class="btn-form-save">
                    @(Id.HasValue && Id.Value > 0 ? "Guardar cambios" : "Crear cliente")
                </button>
            </div>

        </EditForm>

    </div>
}


@code {

    [Parameter]
    public int? Id { get; set; }

    private Cliente _cliente = new();

    private bool _error = false;
    private string _mensajeError = "";

    private List<TipoCliente>
        _tiposCliente = new();

    private List<Interes>
        _intereses = new();

    private List<int>
        _interesesSeleccionados = new();

    protected override async Task
        OnParametersSetAsync()
    {
        _tiposCliente =
            await _repositorioTipoClientes
            .ObtenerTipoClientes();

        _intereses =
            await _repositorioIntereses
            .ObtenerIntereses();

        if (Id.HasValue && Id.Value > 0)
        {
            var cliente =
                await _repositorioClientes
                .ObtenerClientePorId(Id.Value);

            if (cliente == null)
            {
                _error = true;
            }
            else
            {
                _cliente = cliente;

                _interesesSeleccionados =
                    cliente.ClienteIntereses
                    .Select(ci => ci.InteresId)
                    .ToList();
            }
        }
    }

    private void OnInteresChanged(
        int interesId,
        bool seleccionado)
    {
        if (seleccionado)
        {
            if (!_interesesSeleccionados
                .Contains(interesId))
            {
                _interesesSeleccionados
                    .Add(interesId);
            }
        }
        else
        {
            _interesesSeleccionados
                .Remove(interesId);
        }
    }

    private bool
        IsInteresSeleccionado(int id)
    {
        return _interesesSeleccionados
            .Contains(id);
    }

    private async Task Guardar()
    {
        try
        {
            _mensajeError = "";

            if (Id.HasValue && Id.Value > 0)
            {
                await _repositorioClientes
                    .ActualizarCliente(
                        _cliente,
                        _interesesSeleccionados);
            }
            else
            {
                await _repositorioClientes
                    .AgregarCliente(
                        _cliente,
                        _interesesSeleccionados);
            }

            _navigationManager
                .NavigateTo("/clientes");
        }
        catch (Exception ex)
        {
            _mensajeError = ex.Message;
        }
    }

    private void Cancelar()
    {
        _navigationManager
            .NavigateTo("/clientes");
    }
}