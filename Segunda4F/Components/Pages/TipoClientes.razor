@page "/tipoclientes"

@rendermode InteractiveServer

@using Segunda4F.Data
@using Segunda4F.Repositorios
@using Microsoft.AspNetCore.Components.QuickGrid

@inject NavigationManager _navigationManager
@inject IRepositorioTipoClientes _repositorioTipoClientes

<PageTitle>Tipos de Cliente</PageTitle>

<h3 class="page-title">Tipos de Cliente</h3>

<div class="toolbar mb-3">

    <button class="btn btn-new"
            @onclick="Nuevo">
        + Nuevo Tipo
    </button>

    <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input type="text"
               class="search-input"
               placeholder="Buscar por nombre…"
               value="@_busqueda"
               @oninput="@(e => { _busqueda = e.Value?.ToString() ?? string.Empty; StateHasChanged(); })" />
    </div>

</div>

<div class="results-label mb-1">
    Mostrando @_tiposFiltrados.Count de @_tiposCliente.Count tipos
</div>

<div class="table-responsive">
    <QuickGrid Items="_tiposFiltrados.AsQueryable()"
               Class="table"
               Pagination="_paginationState">

        <PropertyColumn Property="@(p => p.Nombre)"
                        Title="Nombre"
                        Sortable="true" />

        <TemplateColumn Title="Acciones">
            <div class="actions">
                <button class="btn btn-sm btn-edit"
                        @onclick="@(() => Edit(context))">
                    Editar
                </button>
                <button class="btn btn-sm btn-delete"
                        @onclick="@(() => Delete(context))">
                    Eliminar
                </button>
            </div>
        </TemplateColumn>

    </QuickGrid>

    <Paginator State="_paginationState" />
</div>

@code {

    private List<TipoCliente> _tiposCliente = new();

    private string _busqueda = string.Empty;

    private List<TipoCliente> _tiposFiltrados =>
        _tiposCliente.Where(t =>
            string.IsNullOrWhiteSpace(_busqueda) ||
            t.Nombre.Contains(_busqueda, StringComparison.OrdinalIgnoreCase)
        ).ToList();

    private PaginationState _paginationState =
        new() { ItemsPerPage = 5 };

    protected override async Task OnInitializedAsync()
    {
        _tiposCliente = await _repositorioTipoClientes.ObtenerTipoClientes();
    }

    private void Nuevo()
    {
        _navigationManager.NavigateTo("/tipoclientes/nueva");
    }

    private void Edit(TipoCliente tipoCliente)
    {
        _navigationManager.NavigateTo(
            $"/tipoclientes/editar/{tipoCliente.Id}");
    }

    private async Task Delete(TipoCliente tipoCliente)
    {
        await _repositorioTipoClientes.EliminarTipoCliente(tipoCliente.Id);
        _tiposCliente.Remove(tipoCliente);
    }
}

