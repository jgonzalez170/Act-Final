@page "/intereses"

@rendermode InteractiveServer

@using Segunda4F.Data
@using Segunda4F.Repositorios
@using Microsoft.AspNetCore.Components.QuickGrid

@inject NavigationManager _navigationManager
@inject IRepositorioIntereses _repositorioIntereses

<PageTitle>Intereses</PageTitle>

<h3 class="page-title">Intereses</h3>

<div class="toolbar mb-3">

    <button class="btn btn-new"
            @onclick="Nuevo">
        + Nuevo Interés
    </button>

    <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input type="text"
               class="search-input"
               placeholder="Buscar por nombre…"
               value="@_busqueda"
               @oninput="@(e => { _busqueda = e.Value?.ToString() ?? string.Empty; StateHasChanged(); })" />
    </div>

</div>

<div class="results-label mb-1">
    Mostrando @_interesesFiltrados.Count de @_intereses.Count intereses
</div>

<div class="table-responsive">
    <QuickGrid Items="_interesesFiltrados.AsQueryable()"
               Class="table"
               Pagination="_paginationState">

        <PropertyColumn Property="@(p => p.Nombre)"
                        Title="Nombre"
                        Sortable="true" />

        <TemplateColumn Title="Acciones">
            <div class="actions">
                <button class="btn btn-sm btn-edit"
                        @onclick="@(() => Edit(context))">
                    Editar
                </button>
                <button class="btn btn-sm btn-delete"
                        @onclick="@(() => Delete(context))">
                    Eliminar
                </button>
            </div>
        </TemplateColumn>

    </QuickGrid>

    <Paginator State="_paginationState" />
</div>

@code {

    private List<Interes> _intereses = new();

    private string _busqueda = string.Empty;

    private List<Interes> _interesesFiltrados =>
        _intereses.Where(i =>
            string.IsNullOrWhiteSpace(_busqueda) ||
            i.Nombre.Contains(_busqueda, StringComparison.OrdinalIgnoreCase)
        ).ToList();

    private PaginationState _paginationState =
        new() { ItemsPerPage = 5 };

    protected override async Task OnInitializedAsync()
    {
        _intereses = await _repositorioIntereses.ObtenerIntereses();
    }

    private void Nuevo()
    {
        _navigationManager.NavigateTo("/intereses/nuevo");
    }

    private void Edit(Interes interes)
    {
        _navigationManager.NavigateTo(
            $"/intereses/editar/{interes.Id}");
    }

    private async Task Delete(Interes interes)
    {
        await _repositorioIntereses.EliminarInteres(interes.Id);
        _intereses.Remove(interes);
    }
}
