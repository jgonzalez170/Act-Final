@page "/clientes/nueva"
@page "/clientes/editar/{Id:int}"

@rendermode InteractiveServer

@using Segunda4F.Data
@using Segunda4F.Repositorios

@inject IRepositorioClientes _repositorioClientes
@inject IRepositorioTipoClientes _repositorioTipoClientes
@inject IRepositorioIntereses _repositorioIntereses
@inject NavigationManager _navigationManager

<PageTitle>Cliente</PageTitle>

<h3>Cliente</h3>

@if (_error)
{
    <div class="alert alert-danger">
        <h2>No se encontró el cliente.</h2>
    </div>
}
else
{
    <EditForm Model="_cliente"
              FormName="frmCliente"
              OnValidSubmit="Guardar">

        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row mb-3">
            <div class="col-2">
                <label>Nombre</label>
            </div>
            <div class="col-10">
                <InputText class="form-control"
                           @bind-Value="_cliente.Nombre" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">
                <label>Teléfono</label>
            </div>
            <div class="col-10">
                <InputText class="form-control"
                           @bind-Value="_cliente.Telefono" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">
                <label>Correo</label>
            </div>
            <div class="col-10">
                <InputText class="form-control"
                           @bind-Value="_cliente.Correo" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">
                <label>Tipo Cliente</label>
            </div>

            <div class="col-10">
                <InputSelect class="form-select"
                             @bind-Value="_cliente.TipoClienteId">

                    <option value="">
                        Seleccione
                    </option>

                    @foreach (var tipo in _tiposCliente)
                    {
                        <option value="@tipo.Id">
                            @tipo.Nombre
                        </option>
                    }

                </InputSelect>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">
                <label>Intereses</label>
            </div>

            <div class="col-10">

                @foreach (var interes in _intereses)
                {
                    <div class="form-check">

                        <input class="form-check-input"
                               type="checkbox"
                               checked="@IsInteresSeleccionado(interes.Id)"
                               @onchange="(e) =>
                               OnInteresChanged(
                               interes.Id,
                               Convert.ToBoolean(e.Value))" />

                <label class="form-check-label">
                    @interes.Nombre
                </label>

                    </div>
                        }

            </div>
        </div>

        <button type="submit"
                class="btn btn-primary">
            Guardar
        </button>

        <button type="button"
                class="btn btn-secondary ms-2"
                @onclick="Cancelar">
            Cancelar
        </button>

    </EditForm>
}

@code {

    [Parameter]
    public int? Id { get; set; }

    private Cliente _cliente = new();

    private bool _error = false;

    private List<TipoCliente>
        _tiposCliente = new();

    private List<Interes>
        _intereses = new();

    private List<int>
        _interesesSeleccionados = new();

    protected override async Task
        OnParametersSetAsync()
    {
        _tiposCliente =
            await _repositorioTipoClientes
            .ObtenerTipoClientes();

        _intereses =
            await _repositorioIntereses
            .ObtenerIntereses();

        if (Id.HasValue && Id.Value > 0)
        {
            var cliente =
                await _repositorioClientes
                .ObtenerClientePorId(Id.Value);

            if (cliente == null)
            {
                _error = true;
            }
            else
            {
                _cliente = cliente;

                _interesesSeleccionados =
                    cliente.ClienteIntereses
                    .Select(ci => ci.InteresId)
                    .ToList();
            }
        }
    }

    private void OnInteresChanged(
        int interesId,
        bool seleccionado)
    {
        if (seleccionado)
        {
            if (!_interesesSeleccionados
                .Contains(interesId))
            {
                _interesesSeleccionados
                    .Add(interesId);
            }
        }
        else
        {
            _interesesSeleccionados
                .Remove(interesId);
        }
    }

    private bool
        IsInteresSeleccionado(int id)
    {
        return _interesesSeleccionados
            .Contains(id);
    }

    private async Task Guardar()
    {
        _cliente.ClienteIntereses =
            _interesesSeleccionados
            .Select(id => new ClienteInteres
            {
                ClienteId = _cliente.Id,
                InteresId = id
            }).ToList();

        if (Id.HasValue && Id.Value > 0)
        {
            await _repositorioClientes
                .ActualizarCliente(
                    _cliente);
        }
        else
        {
            await _repositorioClientes
                .AgregarCliente(
                    _cliente);
        }

        _navigationManager
            .NavigateTo("/clientes");
    }

    private void Cancelar()
    {
        _navigationManager
            .NavigateTo("/clientes");
    }
}