@page "/intereses/nuevo"
@page "/intereses/editar/{Id:int}"

@rendermode InteractiveServer

@using Segunda4F.Data
@using Segunda4F.Repositorios

@inject IRepositorioIntereses _repositorioIntereses
@inject NavigationManager _navigationManager

<PageTitle>@(Id.HasValue && Id.Value > 0 ? "Editar Interés" : "Nuevo Interés")</PageTitle>

@if (_error)
{
    <div class="form-alert form-alert-danger">
        <span class="alert-icon">⚠</span>
        No se encontró el interés.
    </div>
}
else
{
    <div class="form-card">

        <div class="form-card-header">
            <h3 class="form-card-title">
                @(Id.HasValue && Id.Value > 0 ? "Editar Interés" : "Nuevo Interés")
            </h3>
            <p class="form-card-subtitle">
                @(Id.HasValue && Id.Value > 0
                    ? "Modifica el nombre del interés"
                    : "Ingresa el nombre del nuevo interés")
            </p>
        </div>

        <EditForm Model="_interes"
                  FormName="frmInteres"
                  OnValidSubmit="Guardar">

            <DataAnnotationsValidator />
            <ValidationSummary class="form-validation-summary" />

            <div class="form-section">
                <h4 class="form-section-title">Información</h4>

                <div class="form-field">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-input"
                               placeholder="Ej. Tecnología, Deportes…"
                               @bind-Value="_interes.Nombre" />
                    <ValidationMessage For="@(() => _interes.Nombre)" />
                </div>
            </div>

            <div class="form-actions">
                <button type="button"
                        class="btn-form-cancel"
                        @onclick="Cancelar">
                    Cancelar
                </button>
                <button type="submit"
                        class="btn-form-save">
                    @(Id.HasValue && Id.Value > 0 ? "Guardar cambios" : "Crear interés")
                </button>
            </div>

        </EditForm>

    </div>
}

@code {

    [Parameter]
    public int? Id { get; set; }

    private Interes _interes = new();

    private bool _error = false;

    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue && Id.Value > 0)
        {
            var interes = await _repositorioIntereses
                .ObtenerInteresPorId(Id.Value);

            if (interes == null)
                _error = true;
            else
                _interes = interes;
        }
    }

    private async Task Guardar()
    {
        if (Id.HasValue && Id.Value > 0)
            await _repositorioIntereses.ActualizarInteres(_interes);
        else
            await _repositorioIntereses.AgregarInteres(_interes);

        _navigationManager.NavigateTo("/intereses");
    }

    private void Cancelar()
    {
        _navigationManager.NavigateTo("/intereses");
    }
}
